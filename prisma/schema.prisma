// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider     = "mysql"
  url          = env("DATABASE_URL")
  relationMode = "prisma"
}

model movie {
  id           Int       @id
  title        String
  release_date DateTime?
  language     String
  popularity   Float
  vote_count   Int
  vote_average Float
  searches     movie_search[]
  @@index([language])
  @@index([release_date, language])
  @@index([popularity])
  @@index([vote_count, vote_average])
}

model movie_search {
  id           Int       @id @default(autoincrement())
  movie        movie     @relation(fields: [movie_id], references: [id])
  movie_id     Int
  genre        Int
  genre_pair   Int
  provider     Int
  @@index([movie_id])
  @@index([genre, genre_pair])
  @@index([provider, genre, genre_pair])
}

model movie_load {
  id              Int       @id @default(autoincrement())
  type            String
  created_at      DateTime  @default(now())
  updated_at      DateTime? @updatedAt
  start_id        Int
  end_id          Int
  completed_count Int?
}